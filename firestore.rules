rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers --------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.role == 'admin';
    }

    function isPresident() {
      return isAdmin()
        && userDoc(request.auth.uid).data.isPresident == true;
    }

    function onlyChanged(allowedFields) {
      return request.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(allowedFields);
    }

    function notChanged(forbiddenFields) {
      return !request.resource.data.diff(resource.data)
        .affectedKeys().hasAny(forbiddenFields);
    }

    // --- Users ----------------------------------------------------------

    match /users/{uid} {
      allow read: if isSignedIn();

      // Only admins create user profiles (via the secondary-app flow).
      allow create: if isAdmin();

      // Self-update is an explicit allowlist — anything not listed
      // (email, role, isPresident, position, active, joinedAt) can only be
      // changed by an admin or the president. The `stars` field is no
      // longer used by any feature — earned stars and spendable balance are
      // both derived live from approved tasks, attendance, and on-task
      // extensionCount (see StarsService). Legacy values on user docs are
      // ignored.
      allow update: if isSignedIn() && (
        (request.auth.uid == uid
          && onlyChanged(['name', 'phone', 'photoUrl', 'lastReadNotificationsAt']))
        || (isAdmin() && notChanged(['isPresident']))
        || isPresident()
      );

      // Only the president can delete accounts.
      allow delete: if isPresident();
    }

    // --- Collection-group reads ----------------------------------------
    // Required for `collectionGroup('tasks')` queries (Review Queue, My
    // Tasks, admin stats, profile 'Tasks approved' breakdown) and
    // `collectionGroup('attendance')` queries (profile 'Events attended'
    // breakdown, admin 'This month' stars roll-up). Writes stay governed
    // by the nested rules under /events/{eventId}/{tasks|attendance}/...
    match /{path=**}/tasks/{taskId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/attendance/{memberUid} {
      allow read: if isSignedIn();
    }

    // --- Events and subcollections --------------------------------------

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /tasks/{taskId} {
        allow read: if isSignedIn();

        // Admin can create/update/delete freely.
        allow create, delete: if isAdmin();

        // Admin can update anything. Members can either:
        //   (a) submit proof on their own pending/rejected task — transitioning
        //       to 'submitted'. Only permitted before the effective due date
        //       (dueDate, or extensionGrantedUntil if an extension is active).
        //   (b) create/reopen an extension request on their own pending/rejected
        //       task. `extensionCount` must monotonically increase by 1 and
        //       `extensionStarCost` must equal the new count — those two checks
        //       together mean the cost field is derivable from the doc, so the
        //       client can't understate the cost. The corresponding stars-
        //       decrement on /users/{uid} is constrained by the users rule
        //       (can only go down). Review metadata (reviewNote, starsAwarded,
        //       extensionReview*) stays admin-only.
        allow update: if isAdmin() || (
          resource.data.assignedTo == request.auth.uid
          && resource.data.status in ['pending', 'rejected']
          && request.resource.data.status == 'submitted'
          && onlyChanged([
              'proofUrl', 'proofType', 'memberNote',
              'status', 'submittedAt'
          ])
          && (
            resource.data.get('dueDate', null) == null
            || request.time < resource.data.dueDate
            || (resource.data.get('extensionStatus', null) == 'approved'
                && resource.data.get('extensionGrantedUntil', null) != null
                && request.time < resource.data.extensionGrantedUntil)
          )
        ) || (
          // (b) Extension request by the assigned member.
          resource.data.assignedTo == request.auth.uid
          && resource.data.status in ['pending', 'rejected']
          && request.resource.data.status == resource.data.status
          && request.resource.data.extensionStatus == 'pending'
          && request.resource.data.extensionAdminInitiated == false
          && request.resource.data.extensionRequestedDays in [1, 2, 3, 4]
          && request.resource.data.extensionReason is string
          && request.resource.data.extensionReason.size() > 0
          && request.resource.data.extensionCount ==
              (resource.data.get('extensionCount', 0)) + 1
          && request.resource.data.extensionStarCost ==
              request.resource.data.extensionCount
          && onlyChanged([
              'extensionStatus', 'extensionRequestedAt', 'extensionReason',
              'extensionRequestedDays', 'extensionAdminInitiated',
              'extensionStarCost', 'extensionCount',
              'extensionGrantedUntil', 'extensionGrantedDays',
              'extensionReviewedBy', 'extensionReviewedAt', 'extensionReviewNote'
          ])
        );
      }

      match /attendance/{memberUid} {
        allow read: if isSignedIn();

        // Admin can create any attendance entry (manual marking).
        // A member can self-check-in ONLY by presenting the current QR
        // secret of the parent event — verified server-side by comparing
        // request.resource.data.qrSecretUsed against events/{eventId}.qrSecret.
        // Every other field must match the canonical shape so members
        // can't forge userId, starsAwarded, or method.
        allow create: if isSignedIn() && (
          isAdmin()
          || (
            memberUid == request.auth.uid
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.method == 'qr'
            && request.resource.data.starsAwarded == 2
            && request.resource.data.qrSecretUsed is string
            && request.resource.data.qrSecretUsed ==
                 get(/databases/$(database)/documents/events/$(eventId)).data.qrSecret
          )
        );

        // Only admin can modify or delete attendance entries.
        allow update, delete: if isAdmin();
      }

      match /gallery/{photoId} {
        allow read: if isSignedIn();
        // Member may upload only if the stored fields can't spoof identity
        // or point at an arbitrary URL: uploadedBy must equal their uid and
        // the URL must come from our own Cloudinary cloud.
        allow create: if isSignedIn()
          && request.resource.data.uploadedBy == request.auth.uid
          && request.resource.data.url is string
          && request.resource.data.url.matches(
              'https://res\\.cloudinary\\.com/dttox49ht/.*');

        // Uploader or any admin can update/delete their photo.
        allow update, delete: if isSignedIn() && (
          resource.data.uploadedBy == request.auth.uid || isAdmin()
        );
      }

      match /wallet/{docId} {
        allow read: if isSignedIn();
        // Same shape as gallery, plus pin the type enum so members can't
        // mislabel an image as a pdf (or vice-versa) to confuse the counter.
        allow create: if isSignedIn()
          && request.resource.data.uploadedBy == request.auth.uid
          && request.resource.data.type in ['pdf', 'image']
          && request.resource.data.url is string
          && request.resource.data.url.matches(
              'https://res\\.cloudinary\\.com/dttox49ht/.*');

        // Uploader or any admin can update/delete.
        allow update, delete: if isSignedIn() && (
          resource.data.uploadedBy == request.auth.uid || isAdmin()
        );
      }
    }

    // --- Admin-managed content -----------------------------------------

    match /kurals/{date} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
